# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — required for auth and vector search
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PostgreSQL connection string (with pgvector extension)
# Required for production search. Leave unset to use keyword mock search.
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/ats_db

# OpenAI API key — used for semantic (vector) search embeddings
# Required for true semantic search. Leave unset to use keyword hash fallback.
OPENAI_API_KEY=sk-...

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# Email Integration — Google (Gmail) + Microsoft (Outlook/Graph)
# See docs/oauth-setup/google.md and docs/oauth-setup/microsoft.md
# ──────────────────────────────────────────────────────────────────────────────

# Master kill-switch. Set to "false" to disable all email sync in both providers.
EMAIL_SYNC_ENABLED=true
EMAIL_GOOGLE_ENABLED=true
EMAIL_MICROSOFT_ENABLED=true

# Google OAuth + Gmail
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_PUBSUB_PROJECT_ID=
GOOGLE_PUBSUB_TOPIC=gmail-push
GOOGLE_PUBSUB_AUDIENCE=https://app.ikhaya.io

# Microsoft OAuth + Graph
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
MS_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback
# "common" allows any Entra tenant + personal accounts. Use "organizations" for work/school only.
MS_OAUTH_AUTHORITY=https://login.microsoftonline.com/common
MS_GRAPH_WEBHOOK_URL=https://app.ikhaya.io/api/webhooks/graph
# Generate with: openssl rand -hex 32
MS_GRAPH_WEBHOOK_CLIENT_STATE_SECRET=

# Token encryption at rest. Generate with: openssl rand -base64 32
EMAIL_TOKEN_ENCRYPTION_KEY=

# Sync tuning
EMAIL_BACKFILL_DAYS=90
EMAIL_SYNC_RATE_LIMIT_PER_USER=20
EMAIL_FUZZY_MATCH_FLOOR=0.82

# Queue (added in Stage 6)
REDIS_URL=redis://localhost:6379

# Object storage for email bodies (S3 / R2)
EMAIL_BODIES_BUCKET=
EMAIL_BODIES_BUCKET_REGION=auto
EMAIL_BODIES_BUCKET_ENDPOINT=
EMAIL_BODIES_BUCKET_ACCESS_KEY=
EMAIL_BODIES_BUCKET_SECRET_KEY=
